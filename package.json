{
  "name": "al-pocket-tools",
  "displayName": "AL Pocket Tools",
  "description": "Collection of tools for AL (Business Central) development",
  "version": "0.15.1",
  "publisher": "teddyherryanto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thatnavguy/AL-Pocket-Tools.git"
  },
  "bugs": {
    "url": "https://github.com/thatnavguy/AL-Pocket-Tools/issues"
  },
  "homepage": "https://github.com/thatnavguy/AL-Pocket-Tools#readme",
  "keywords": [
    "al",
    "business central",
    "dynamics 365",
    "nav",
    "alpackages",
    "region viewer",
    "pragma viewer",
    "version bump"
  ],
  "engines": {
    "vscode": "^1.118.0"
  },
  "icon": "image/icon.png",
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:al",
    "onCommand:al-pocket-tools.bumpVersion",
    "onCommand:al-pocket-tools.nukeAlPackages",
    "onCommand:al-pocket-tools.syncAlPackages",
    "onCommand:al-pocket-tools.pasteLaunchConfig",
    "onCommand:al-pocket-tools.saveLaunchConfig",
    "onCommand:al-pocket-tools.clearLaunchConfigs",
    "onCommand:al-pocket-tools.showProcedureVisibility",
    "onCommand:al-pocket-tools.changeProcedureVisibility",
    "onCommand:al-pocket-tools.changeProcedureVisibilityProject",
    "onCommand:al-pocket-tools.toggleRainbowIndent",
    "onView:al-pocket-tools.assignmentTracker",
    "onCommand:al-pocket-tools.copyFileTo",
    "onCommand:al-pocket-tools.moveFileTo"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "al-pocket-tools.cleanupAppFiles",
        "title": "Cleanup Duplicate App Files",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.nukeAlPackages",
        "title": "Nuke .alpackages",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.syncAlPackages",
        "title": "Sync .alpackages to Latest",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.refreshRegionViewer",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.refreshPragmaViewer",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.bumpVersion",
        "title": "Bump Version...",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.incrementMajor",
        "title": "Increment Major Version",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.incrementMinor",
        "title": "Increment Minor Version",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.incrementBuild",
        "title": "Increment Build Version",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.incrementRevision",
        "title": "Increment Revision Version",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.pasteLaunchConfig",
        "title": "Paste Launch Configuration",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.saveLaunchConfig",
        "title": "Save Launch Configuration",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.clearLaunchConfigs",
        "title": "Clear Launch Configurations",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.showProcedureVisibility",
        "title": "Show Procedure Visibility",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.changeProcedureVisibility",
        "title": "Change Procedure Visibility...",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.changeProcedureVisibilityProject",
        "title": "Change Procedure Visibility... (Project)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.refreshReportViewer",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.toggleRainbowIndent",
        "title": "Toggle Rainbow Indent",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.searchAssignments",
        "title": "Search Assignments...",
        "icon": "$(search)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.refreshAssignmentTracker",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.toggleAssignmentTrackerScope",
        "title": "Toggle Scope (Workspace / File)",
        "icon": "$(globe)",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.addSetLoadFields",
        "title": "Add SetLoadFields",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.removeCaptionSuffix",
        "title": "Remove Caption Suffix...",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.removeCaptionPrefix",
        "title": "Remove Caption Prefix...",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.convertAssignmentToValidate",
        "title": "Convert Assignment to Validate",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.copyFileTo",
        "title": "Copy File To...",
        "category": "AL Pocket Tools"
      },
      {
        "command": "al-pocket-tools.moveFileTo",
        "title": "Move File To...",
        "category": "AL Pocket Tools"
      }
    ],
    "submenus": [
      {
        "id": "al-pocket-tools.editorAlSubmenu",
        "label": "AL Pocket Tools"
      },
      {
        "id": "al-pocket-tools.editorLaunchSubmenu",
        "label": "AL Pocket Tools"
      },
      {
        "id": "al-pocket-tools.explorerFileSubmenu",
        "label": "AL Pocket Tools"
      }
    ],
    "keybindings": [
      {
        "command": "al-pocket-tools.toggleRainbowIndent",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "al-pocket-tools.bumpVersion",
          "when": "resourceFilename == app.json",
          "group": "al-pocket-tools@1"
        },
        {
          "submenu": "al-pocket-tools.explorerFileSubmenu",
          "when": "!explorerResourceIsFolder",
          "group": "al-pocket-tools@2"
        }
      ],
      "editor/context": [
        {
          "submenu": "al-pocket-tools.editorAlSubmenu",
          "when": "resourceExtname == .al",
          "group": "al-pocket-tools@1"
        },
        {
          "submenu": "al-pocket-tools.editorLaunchSubmenu",
          "when": "resourceFilename == launch.json",
          "group": "al-pocket-tools@1"
        }
      ],
      "al-pocket-tools.editorAlSubmenu": [
        {
          "command": "al-pocket-tools.addSetLoadFields",
          "group": "1_performance@1"
        },
        {
          "command": "al-pocket-tools.showProcedureVisibility",
          "group": "2_analysis@1"
        },
        {
          "command": "al-pocket-tools.changeProcedureVisibility",
          "group": "2_analysis@2"
        },
        {
          "command": "al-pocket-tools.searchAssignments",
          "group": "3_search@1"
        },
        {
          "command": "al-pocket-tools.removeCaptionPrefix",
          "group": "4_captions@1"
        },
        {
          "command": "al-pocket-tools.removeCaptionSuffix",
          "group": "4_captions@2"
        },
        {
          "command": "al-pocket-tools.convertAssignmentToValidate",
          "group": "5_refactor@1",
          "when": "editorHasSelection"
        }
      ],
      "al-pocket-tools.editorLaunchSubmenu": [
        {
          "command": "al-pocket-tools.pasteLaunchConfig",
          "group": "1_launch@1"
        },
        {
          "command": "al-pocket-tools.saveLaunchConfig",
          "group": "1_launch@2"
        },
        {
          "command": "al-pocket-tools.clearLaunchConfigs",
          "group": "1_launch@3"
        }
      ],
      "al-pocket-tools.explorerFileSubmenu": [
        {
          "command": "al-pocket-tools.cleanupAppFiles",
          "when": "resourceExtname == .app",
          "group": "1_cleanup@1"
        },
        {
          "command": "al-pocket-tools.copyFileTo",
          "group": "2_fileSender@1"
        },
        {
          "command": "al-pocket-tools.moveFileTo",
          "group": "2_fileSender@2"
        }
      ],
      "view/title": [
        {
          "command": "al-pocket-tools.refreshRegionViewer",
          "when": "view == al-pocket-tools.regionViewer",
          "group": "navigation"
        },
        {
          "command": "al-pocket-tools.refreshPragmaViewer",
          "when": "view == al-pocket-tools.pragmaViewer",
          "group": "navigation"
        },
        {
          "command": "al-pocket-tools.refreshReportViewer",
          "when": "view == al-pocket-tools.reportViewer",
          "group": "navigation"
        },
        {
          "command": "al-pocket-tools.refreshAssignmentTracker",
          "when": "view == al-pocket-tools.assignmentTracker",
          "group": "navigation"
        },
        {
          "command": "al-pocket-tools.toggleAssignmentTrackerScope",
          "when": "view == al-pocket-tools.assignmentTracker",
          "group": "navigation"
        },
        {
          "command": "al-pocket-tools.searchAssignments",
          "when": "view == al-pocket-tools.assignmentTracker",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "al-pocket-tools",
          "title": "AL Pocket Tools",
          "icon": "image/al-pocket-tools-sidebar.png"
        }
      ]
    },
    "views": {
      "al-pocket-tools": [
        {
          "id": "al-pocket-tools.assignmentTracker",
          "name": "Assignment Tracker"
        },
        {
          "id": "al-pocket-tools.pragmaViewer",
          "name": "Pragma Viewer"
        }
      ],
      "explorer": [
        {
          "id": "al-pocket-tools.regionViewer",
          "name": "Region Viewer"
        },
        {
          "id": "al-pocket-tools.reportViewer",
          "name": "Report Viewer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "al-pocket-tools.regionViewer",
        "when": "al-pocket-tools:regionViewerMode == manual || !al-pocket-tools:regionViewerMode",
        "contents": "Open an AL file and click Refresh to see its regions.\n\n[Refresh](command:al-pocket-tools.refreshRegionViewer)"
      },
      {
        "view": "al-pocket-tools.regionViewer",
        "when": "al-pocket-tools:regionViewerMode == onOpenFile",
        "contents": "Open an AL file to see its regions."
      },
      {
        "view": "al-pocket-tools.pragmaViewer",
        "contents": "No pragma directives found in the workspace.\n\n[Refresh](command:al-pocket-tools.refreshPragmaViewer)"
      },
      {
        "view": "al-pocket-tools.reportViewer",
        "when": "al-pocket-tools:reportViewerMode == manual || !al-pocket-tools:reportViewerMode",
        "contents": "Open an AL report file and click Refresh to see its structure.\n\n[Refresh](command:al-pocket-tools.refreshReportViewer)"
      },
      {
        "view": "al-pocket-tools.reportViewer",
        "when": "al-pocket-tools:reportViewerMode == onOpenFile",
        "contents": "Open an AL report file to see its structure."
      },
      {
        "view": "al-pocket-tools.assignmentTracker",
        "contents": "Place your cursor on a field name in an AL file and run Search Assignments, or use the search button above.\n\n[Search Assignments](command:al-pocket-tools.searchAssignments)"
      }
    ],
    "configuration": {
      "title": "AL Pocket Tools",
      "properties": {
        "al-pocket-tools.regionViewer.refreshMode": {
          "type": "string",
          "default": "manual",
          "enum": ["manual", "onOpenFile"],
          "enumDescriptions": [
            "Refresh only when you click the Refresh button in the Region Viewer title bar.",
            "Automatically refresh when you switch to a different file in the editor. Only runs when the Region Viewer is visible."
          ],
          "description": "Controls when the Region Viewer updates its content."
        },
        "al-pocket-tools.launch.configurations": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["name", "type", "request"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "request": { "type": "string" }
            },
            "additionalProperties": true
          },
          "description": "Saved AL launch configurations. Right-click in launch.json to paste or save configurations."
        },
        "al-pocket-tools.procedureVisibility.reportStyle": {
          "type": "string",
          "default": "list",
          "enum": ["list", "dialog"],
          "enumDescriptions": [
            "Show a searchable list of all procedures with their visibility and line number. Select a procedure to navigate to it.",
            "Show a simple counts-only dialog: how many procedures are Local, Internal, and Public."
          ],
          "description": "Controls how the Procedure Visibility report is displayed."
        },
        "al-pocket-tools.procedureVisibility.confirmationStyle": {
          "type": "string",
          "default": "once",
          "enum": ["once", "perProcedure"],
          "enumDescriptions": [
            "Show a single confirmation dialog before changing all procedures at once.",
            "Confirm each procedure change individually, with Yes / Yes to All / Skip / Cancel options."
          ],
          "description": "Controls how procedure visibility changes are confirmed. The project-wide command always uses 'once'."
        },
        "al-pocket-tools.reportViewer.refreshMode": {
          "type": "string",
          "default": "manual",
          "enum": ["manual", "onOpenFile"],
          "enumDescriptions": [
            "Refresh only when you click the Refresh button in the Report Viewer title bar.",
            "Automatically refresh when you switch to a different file in the editor. Only runs when the Report Viewer is visible."
          ],
          "description": "Controls when the Report Viewer updates its content."
        },
        "al-pocket-tools.reportViewer.showVarDeclarations": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, the Report Viewer expands the var section to list individual variable declarations. When disabled (default), only the var section header is shown with a count."
        },
        "al-pocket-tools.rainbowIndent.onEditorSwitch": {
          "type": "string",
          "default": "autoHide",
          "enum": ["autoHide", "follow"],
          "enumDescriptions": [
            "Rainbow indent is dismissed when you switch to a different editor tab.",
            "Rainbow indent follows you to the new editor tab and re-applies there."
          ],
          "description": "Controls what happens to Rainbow Indent when you switch to a different editor tab. Typing always dismisses it regardless of this setting."
        },
        "al-pocket-tools.assignmentTracker.includeTransferFields": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, TransferFields() calls are included in Assignment Tracker results with a 'bulk assign' indicator. Disable to show only direct assignments and Validate calls."
        },
        "al-pocket-tools.captionAffix.defaultSuffix": {
          "type": "string",
          "default": "",
          "description": "Default suffix pre-filled when running 'Remove Caption Suffix'. Leave empty to always prompt without a default."
        },
        "al-pocket-tools.captionAffix.defaultPrefix": {
          "type": "string",
          "default": "",
          "description": "Default prefix pre-filled when running 'Remove Caption Prefix'. Leave empty to always prompt without a default."
        },
        "al-pocket-tools.fileSender.savedFolders": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["label", "path"],
            "properties": {
              "label": { "type": "string", "description": "Friendly display name shown in the folder picker." },
              "path": { "type": "string", "description": "Absolute path to the folder." }
            }
          },
          "description": "Saved destination folders shown in the Copy/Move File To picker."
        },
        "al-pocket-tools.fileSender.saveBrowsedFolder": {
          "type": "string",
          "default": "always",
          "enum": ["always", "ask", "never"],
          "enumDescriptions": [
            "Automatically prompt to name and save any browsed folder to the favourites list.",
            "Ask whether to save the browsed folder each time.",
            "Never save browsed folders — use the picker without persisting anything."
          ],
          "description": "Controls whether a folder chosen via 'Browse for folder...' is saved to the favourites list."
        },
        "al-pocket-tools.setLoadFields.readIsolation": {
          "type": "string",
          "default": "ReadUncommitted",
          "enum": ["None", "ReadUncommitted", "ReadCommitted", "RepeatableRead", "UpdLock"],
          "enumDescriptions": [
            "Do not insert a ReadIsolation line.",
            "Insert IsolationLevel::ReadUncommitted — best performance for read-only lookups (no shared locks).",
            "Insert IsolationLevel::ReadCommitted — avoids dirty reads.",
            "Insert IsolationLevel::RepeatableRead — prevents non-repeatable reads within a transaction.",
            "Insert IsolationLevel::UpdLock — acquires an update lock on the rows read, preventing deadlocks on subsequent writes."
          ],
          "description": "Controls whether a ReadIsolation assignment is inserted alongside SetLoadFields, and which isolation level to use. Set to None to skip."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
